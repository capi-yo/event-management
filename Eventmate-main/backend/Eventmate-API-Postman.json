{
    "info": {
        "name": "Eventmate API",
        "description": "Postman collection for Eventmate RESTful API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "authToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "eventId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Health Check",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/health"
                    }
                }
            ]
        },
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Current User",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/auth/me",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "User Profile",
            "item": [
                {
                    "name": "Get Profile",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/user/profile",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Update Profile",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/user/profile",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"John Updated\"\n}"
                        }
                    }
                },
                {
                    "name": "Change Password",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/user/password",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"currentPassword\": \"password123\",\n    \"newPassword\": \"newpassword456\"\n}"
                        }
                    }
                },
                {
                    "name": "Get My Events",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/user/my-events",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Get Notifications",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/user/notifications",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "Events",
            "item": [
                {
                    "name": "List Events (Public)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/events?page=1&limit=10",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Search Events",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/events?category=Music&search=concert",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events"
                            ],
                            "query": [
                                {
                                    "key": "category",
                                    "value": "Music"
                                },
                                {
                                    "key": "search",
                                    "value": "concert"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Event Details",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/events/{{eventId}}",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Create Event (Organizer)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/events",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Community Music Festival\",\n    \"description\": \"A day of music and fun\",\n    \"category\": \"Music\",\n    \"date\": \"2026-06-15\",\n    \"time\": \"14:00\",\n    \"location_venue\": \"Central Park\",\n    \"location_latitude\": 40.7829,\n    \"location_longitude\": -73.9654,\n    \"capacity\": 500,\n    \"is_paid\": false\n}"
                        }
                    }
                },
                {
                    "name": "Update Event",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/events/{{eventId}}",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Updated Event Title\",\n    \"description\": \"Updated description\",\n    \"capacity\": 600\n}"
                        }
                    }
                },
                {
                    "name": "Delete Event",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/events/{{eventId}}",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "Registrations & Tickets",
            "item": [
                {
                    "name": "RSVP to Event",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/events/{{eventId}}/rsvp",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Purchase Ticket",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/events/{{eventId}}/purchase",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"ticket_type\": \"VIP\",\n    \"payment_method\": \"credit_card\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Admin",
            "item": [
                {
                    "name": "Get Pending Events",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/admin/pending-events",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Update Event Status",
                    "request": {
                        "method": "PATCH",
                        "url": "{{baseUrl}}/admin/events/{{eventId}}/status",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"status\": \"Approved\"\n}"
                        }
                    }
                },
                {
                    "name": "Get All Users",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/admin/users",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Update User Role",
                    "request": {
                        "method": "PATCH",
                        "url": "{{baseUrl}}/admin/users/1/role",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"role\": \"Organizer\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Activity Logs",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/admin/logs",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Get System Stats",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/admin/stats",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "Notifications",
            "item": [
                {
                    "name": "Send Notification to User",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/notifications/send",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"user_id\": 1,\n    \"message\": \"Your event has been approved!\"\n}"
                        }
                    }
                },
                {
                    "name": "Send Notification to Event Attendees",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/notifications/send",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"event_id\": 1,\n    \"message\": \"Reminder: Event starts tomorrow!\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Notification Templates",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/notifications/templates",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ]
                    }
                }
            ]
        }
    ]
}