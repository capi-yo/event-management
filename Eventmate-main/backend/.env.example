# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eventmate
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Application URL (for CORS)
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:3000

# EventMate Local Bank (virtual wallet for demos)
BANK_STARTING_BALANCE=1000
BANK_MAX_DEPOSIT=10000

# SMTP (required for help-center contact form and auth emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Help center messages are delivered to this inbox
SUPPORT_EMAIL=tihitnaejigu@gmail.com
